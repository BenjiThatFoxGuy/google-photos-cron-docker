From b0cd78515a17c4073598256cf32545a2dc30d1a4 Mon Sep 17 00:00:00 2001
From: Build <patch@build>
Date: Mon, 20 Apr 2026 23:18:38 +0000
Subject: [PATCH 2/4] build(cli): split album Wails init() into album_gui.go

Moves the Wails-dependent init() block out of album.go into a new
album_gui.go file guarded by //go:build !cli.  album.go becomes
dependency-free so it compiles cleanly in CLI builds.
---
 backend/album.go     |  6 ------
 backend/album_gui.go | 11 +++++++++++
 2 files changed, 11 insertions(+), 6 deletions(-)
 create mode 100644 backend/album_gui.go

diff --git a/backend/album.go b/backend/album.go
index 384b115..8a64f68 100644
--- a/backend/album.go
+++ b/backend/album.go
@@ -5,7 +5,6 @@ import (
 	"strings"
 	"time"
 
-	"github.com/wailsapp/wails/v3/pkg/application"
 )
 
 // AlbumError represents an album creation error
@@ -14,11 +13,6 @@ type AlbumError struct {
 	Error     string `json:"Error"`
 }
 
-func init() {
-	application.RegisterEvent[AlbumStatus]("albumProgress")
-	application.RegisterEvent[AlbumStatus]("albumComplete")
-	application.RegisterEvent[AlbumError]("albumError")
-}
 
 const (
 	// AlbumBatchSize is the maximum number of items per API call
diff --git a/backend/album_gui.go b/backend/album_gui.go
new file mode 100644
index 0000000..4a7fcec
--- /dev/null
+++ b/backend/album_gui.go
@@ -0,0 +1,11 @@
+//go:build !cli
+
+package backend
+
+import "github.com/wailsapp/wails/v3/pkg/application"
+
+func init() {
+	application.RegisterEvent[AlbumStatus]("albumProgress")
+	application.RegisterEvent[AlbumStatus]("albumComplete")
+	application.RegisterEvent[AlbumError]("albumError")
+}
